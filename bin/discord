#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "trackbot/report"

begin
  reporter = Trackbot::Report.new
  reporter.call
rescue Trackbot::CurrentScores::NoCurrentLeaderboardError
  reporter.no_leaderboard
  warn "No current leaderboard found — alert sent to Discord."
  exit 1
rescue Trackbot::ApiError => e
  warn "Error: #{e.message}"
  exit 1
end
